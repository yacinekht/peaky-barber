{% extends 'base.html.twig' %}

{% block title %}Réserver — Peaky Barber{% endblock %}

{% block stylesheets %}
    <style>
        .booking-wrapper {
            max-width: 760px;
            margin: 60px auto;
            padding: 0 24px 80px;
        }
        .booking-tag {
            font-size: 11px;
            letter-spacing: 5px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 12px;
        }
        .booking-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 52px;
            color: var(--light);
            letter-spacing: 2px;
            margin-bottom: 8px;
        }
        .booking-subtitle { color: #666; font-size: 14px; margin-bottom: 48px; }

        .booking-form {
            background: var(--grey);
            border: 1px solid #222;
            padding: 48px;
        }
        .form-section { margin-bottom: 36px; }
        .form-section-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 18px;
            color: var(--gold);
            letter-spacing: 3px;
            border-bottom: 1px solid #2a2a2a;
            padding-bottom: 10px;
            margin-bottom: 24px;
        }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .form-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
        .form-group label {
            font-size: 11px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #888;
        }
        .form-group input,
        .form-group select {
            background: var(--darker);
            border: 1px solid #2a2a2a;
            color: var(--text);
            padding: 14px 16px;
            font-family: 'Lato', sans-serif;
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;
            width: 100%;
            color-scheme: dark;
        }
        .form-group input:focus,
        .form-group select:focus { border-color: var(--gold); }
        .form-group select option { background: #111; }
        .form-errors { color: #ff6b6b; font-size: 12px; margin-top: 4px; }
        .form-submit { margin-top: 36px; }

        @media (max-width: 600px) {
            .booking-form { padding: 28px 20px; }
            .form-row { grid-template-columns: 1fr; }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="booking-wrapper">
        <p class="booking-tag">✦ Réservation en ligne</p>
        <h1 class="booking-title">Votre Rendez-vous</h1>
        <p class="booking-subtitle">Réservez en quelques secondes. Confirmation immédiate.</p>

        {{ form_start(form, {'attr': {'class': 'booking-form', 'novalidate': 'novalidate'}}) }}

        <div class="form-section">
            <div class="form-section-title">01 — Votre choix</div>
            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.service) }}
                    {{ form_widget(form.service) }}
                    <div class="form-errors">{{ form_errors(form.service) }}</div>
                </div>
                <div class="form-group">
                    {{ form_label(form.barber) }}
                    {{ form_widget(form.barber) }}
                    <div class="form-errors">{{ form_errors(form.barber) }}</div>
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-title">02 — Date & Heure</div>
            <div class="form-group" style="max-width: 320px;">
                {{ form_label(form.appointmentAt) }}
                {{ form_widget(form.appointmentAt) }}
                <div class="form-errors">{{ form_errors(form.appointmentAt) }}</div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-title">03 — Vos coordonnées</div>
            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.clientName) }}
                    {{ form_widget(form.clientName) }}
                    <div class="form-errors">{{ form_errors(form.clientName) }}</div>
                </div>
                <div class="form-group">
                    {{ form_label(form.clientEmail) }}
                    {{ form_widget(form.clientEmail) }}
                    <div class="form-errors">{{ form_errors(form.clientEmail) }}</div>
                </div>
            </div>
            <div class="form-group" style="max-width:300px">
                {{ form_label(form.clientPhone) }}
                {{ form_widget(form.clientPhone) }}
            </div>
        </div>

        <div class="form-submit">
            <button type="submit" class="btn">Confirmer la réservation</button>
        </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
