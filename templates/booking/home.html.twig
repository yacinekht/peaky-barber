{% extends 'base.html.twig' %}

{% block title %}Peaky Barber — Barbershop à votre service{% endblock %}

{% block stylesheets %}
<style>
    /* HERO */
    .hero {
        min-height: 92vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 40px;
        background:
            linear-gradient(to bottom, rgba(8,8,8,0.55) 0%, rgba(13,13,13,0.85) 100%),
            url('https://images.unsplash.com/photo-1503951914875-452162b0f3f1?w=1600&q=80') center/cover no-repeat;
        position: relative;
    }
    .hero-tag {
        font-size: 12px;
        letter-spacing: 5px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 20px;
    }
    .hero h1 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(60px, 10vw, 130px);
        line-height: 0.9;
        color: var(--light);
        margin-bottom: 24px;
    }
    .hero h1 span { color: var(--gold); }
    .hero p {
        font-size: 16px;
        color: #aaa;
        max-width: 480px;
        margin: 0 auto 40px;
        line-height: 1.7;
    }
    .hero-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

    /* SECTION */
    section { padding: 100px 40px; max-width: 1200px; margin: 0 auto; }
    .section-tag {
        font-size: 11px;
        letter-spacing: 5px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 12px;
    }
    .section-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(36px, 5vw, 60px);
        color: var(--light);
        margin-bottom: 60px;
    }

    /* SERVICES */
    .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 2px;
    }
    .service-card {
        background: var(--grey);
        padding: 40px 32px;
        border-bottom: 2px solid transparent;
        transition: border-color 0.2s, background 0.2s;
    }
    .service-card:hover { border-color: var(--gold); background: var(--grey2); }
    .service-name {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 22px;
        color: var(--light);
        letter-spacing: 2px;
        margin-bottom: 10px;
    }
    .service-desc {
        font-size: 13px;
        color: #777;
        line-height: 1.6;
        margin-bottom: 20px;
    }
    .service-footer { display: flex; justify-content: space-between; align-items: center; }
    .service-price { color: var(--gold); font-size: 20px; font-weight: 700; }
    .service-duration { font-size: 12px; color: #555; letter-spacing: 1px; }

    /* BARBERS */
    .barbers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 24px;
    }
    .barber-card {
        background: var(--grey);
        overflow: hidden;
    }
    .barber-photo {
        width: 100%;
        height: 320px;
        object-fit: cover;
        display: block;
        background: var(--grey2);
    }
    .barber-photo-placeholder {
        width: 100%;
        height: 320px;
        background: var(--grey2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 60px;
        color: #333;
    }
    .barber-info { padding: 24px; }
    .barber-name {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 22px;
        color: var(--light);
        letter-spacing: 2px;
        margin-bottom: 4px;
    }
    .barber-speciality { color: var(--gold); font-size: 12px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; }
    .barber-bio { font-size: 13px; color: #666; line-height: 1.6; }

    /* CTA */
    .cta-band {
        background: var(--grey);
        border-top: 1px solid #222;
        border-bottom: 1px solid #222;
        padding: 80px 40px;
        text-align: center;
    }
    .cta-band h2 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(30px, 5vw, 56px);
        color: var(--light);
        margin-bottom: 16px;
    }
    .cta-band p { color: #666; margin-bottom: 32px; font-size: 15px; }
</style>
{% endblock %}

{% block body %}

{# HERO #}
<div class="hero">
    <div>
        <p class="hero-tag">✦ Barbershop depuis 2018 ✦</p>
        <h1>Peaky<br><span>Barber</span></h1>
        <p>L'art de la coupe masculine. Précision, style et savoir-faire traditionnel dans un cadre unique.</p>
        <div class="hero-btns">
            <a href="{{ path('booking_new') }}" class="btn">Réserver maintenant</a>
            <a href="#services" class="btn btn-outline">Nos services</a>
        </div>
    </div>
</div>

{# SERVICES #}
<section id="services">
    <p class="section-tag">✦ Ce que nous proposons</p>
    <h2 class="section-title">Nos Services</h2>
    <div class="services-grid">
        {% for service in services %}
        <div class="service-card">
            <div class="service-name">{{ service.name }}</div>
            {% if service.description %}
                <div class="service-desc">{{ service.description }}</div>
            {% endif %}
            <div class="service-footer">
                <span class="service-price">{{ service.priceFormatted }}</span>
                <span class="service-duration">{{ service.duration }} min</span>
            </div>
        </div>
        {% else %}
        <p style="color:#555">Aucun service disponible pour le moment.</p>
        {% endfor %}
    </div>
</section>

{# BARBERS #}
<section id="equipe" style="background: var(--grey); max-width:100%; padding: 100px 40px;">
    <div style="max-width:1200px; margin:0 auto">
        <p class="section-tag">✦ Notre équipe</p>
        <h2 class="section-title">Les Artisans</h2>
        <div class="barbers-grid">
            {% for barber in barbers %}
            <div class="barber-card">
                {% if barber.photo %}
                    <img src="/uploads/barbers/{{ barber.photo }}" alt="{{ barber.name }}" class="barber-photo">
                {% else %}
                    <div class="barber-photo-placeholder">✂</div>
                {% endif %}
                <div class="barber-info">
                    <div class="barber-name">{{ barber.name }}</div>
                    {% if barber.speciality %}
                        <div class="barber-speciality">{{ barber.speciality }}</div>
                    {% endif %}
                    {% if barber.bio %}
                        <div class="barber-bio">{{ barber.bio }}</div>
                    {% endif %}
                </div>
            </div>
            {% else %}
            <p style="color:#555">Aucun coiffeur disponible pour le moment.</p>
            {% endfor %}
        </div>
    </div>
</section>

{# CTA #}
<div class="cta-band" id="reservation" >
    <h2>Prêt pour une nouvelle coupe ?</h2>
    <p>Réservez en ligne en moins de 2 minutes. Sans compte requis.</p>
    <a href="{{ path('booking_new') }}" class="btn">Prendre rendez-vous</a>
</div>

{% endblock %}
