<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Peaky Barber{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #C9A84C;
            --dark: #0D0D0D;
            --darker: #080808;
            --light: #F5F0E8;
            --grey: #1A1A1A;
            --grey2: #2A2A2A;
            --text: #D4CFC6;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: var(--dark);
            color: var(--text);
            font-family: 'Lato', sans-serif;
            font-weight: 300;
            min-height: 100vh;
        }
        nav {
            background: var(--darker);
            border-bottom: 1px solid #222;
            padding: 0 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 70px;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .nav-logo {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 28px;
            color: var(--gold);
            letter-spacing: 3px;
            text-decoration: none;
        }
        .nav-logo span { color: var(--light); }
        nav ul { list-style: none; display: flex; gap: 32px; }
        nav ul a {
            color: var(--text);
            text-decoration: none;
            font-size: 13px;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: color 0.2s;
        }
        nav ul a:hover { color: var(--gold); }
        .btn {
            display: inline-block;
            padding: 14px 36px;
            background: var(--gold);
            color: var(--dark);
            font-family: 'Bebas Neue', sans-serif;
            font-size: 16px;
            letter-spacing: 3px;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn:hover { background: #e8c060; transform: translateY(-1px); }
        .btn-outline {
            background: transparent;
            border: 1px solid var(--gold);
            color: var(--gold);
        }
        .btn-outline:hover { background: var(--gold); color: var(--dark); }
        .flash-messages { padding: 0 40px; margin-top: 20px; }
        .flash-success {
            background: rgba(201,168,76,0.15);
            border-left: 3px solid var(--gold);
            padding: 16px 20px;
            color: var(--gold);
            font-size: 14px;
        }
        .flash-error {
            background: rgba(220,50,50,0.15);
            border-left: 3px solid #dc3232;
            padding: 16px 20px;
            color: #ff6b6b;
            font-size: 14px;
        }
        footer {
            background: var(--darker);
            border-top: 1px solid #1a1a1a;
            padding: 40px;
            text-align: center;
            color: #555;
            font-size: 13px;
            margin-top: 80px;
        }
        footer strong { color: var(--gold); font-family: 'Bebas Neue', sans-serif; font-size: 18px; letter-spacing: 2px; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <nav>
        <a href="{{ path('home') }}" class="nav-logo">Peaky<span>Barber</span></a>
        <ul>
            <li><a href="{{ path('home') }}">Accueil</a></li>
            <li><a href="{{ path('home') }}#services">Services</a></li>
            <li><a href="{{ path('home') }}#equipe">Notre équipe</a></li>
            <li><a href="{{ path('home') }}#reservation">Réserver</a></li>
        </ul>
        <a href="{{ path('booking_new') }}" class="btn">Prendre RDV</a>
    </nav>

    <div class="flash-messages">
        {% for msg in app.flashes('success') %}
            <div class="flash-success">✓ {{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="flash-error">✗ {{ msg }}</div>
        {% endfor %}
    </div>

    {% block body %}{% endblock %}

    <footer>
        <strong>PeakyBarber</strong><br>
        <p style="margin-top:8px">© {{ "now"|date("Y") }} Peaky Barber — Tous droits réservés</p>
    </footer>

    {% block javascripts %}{% endblock %}
</body>
</html>
