{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Dashboard{% endblock %}

{% block main %}
<style>
    .db-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }
    .stat-card {
        background: #fff;
        border-radius: 4px;
        padding: 28px 24px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        border-top: 3px solid #ccc;
        text-align: center;
    }
    .stat-card.gold   { border-color: #C9A84C; }
    .stat-card.green  { border-color: #28a745; }
    .stat-card.red    { border-color: #dc3545; }
    .stat-number {
        font-size: 48px;
        font-weight: 700;
        line-height: 1;
        margin-bottom: 8px;
    }
    .stat-card.gold   .stat-number { color: #C9A84C; }
    .stat-card.green  .stat-number { color: #28a745; }
    .stat-card.red    .stat-number { color: #dc3545; }
    .stat-label { font-size: 13px; color: #888; letter-spacing: 1px; text-transform: uppercase; }

    .upcoming-table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 4px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
    .upcoming-table th {
        background: #f8f9fa;
        padding: 12px 16px;
        text-align: left;
        font-size: 12px;
        color: #888;
        letter-spacing: 1px;
        text-transform: uppercase;
        border-bottom: 1px solid #eee;
    }
    .upcoming-table td {
        padding: 14px 16px;
        font-size: 14px;
        border-bottom: 1px solid #f5f5f5;
        color: #444;
    }
    .upcoming-table tr:last-child td { border-bottom: none; }
    .badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 100px;
        font-size: 11px;
        font-weight: 600;
    }
    .badge-warning  { background: #fff3cd; color: #856404; }
    .badge-success  { background: #d1e7dd; color: #0a3622; }
    .badge-danger   { background: #f8d7da; color: #842029; }
    .section-head { margin: 32px 0 16px; font-size: 18px; font-weight: 700; color: #333; }
</style>

<div class="db-grid">
    <div class="stat-card gold">
        <div class="stat-number">{{ pending }}</div>
        <div class="stat-label">En attente</div>
    </div>
    <div class="stat-card green">
        <div class="stat-number">{{ confirmed }}</div>
        <div class="stat-label">Confirmées</div>
    </div>
    <div class="stat-card red">
        <div class="stat-number">{{ cancelled }}</div>
        <div class="stat-label">Annulées</div>
    </div>
    <div class="stat-card">
        <div class="stat-number" style="color:#333">{{ upcoming|length }}</div>
        <div class="stat-label">À venir (affiché)</div>
    </div>
</div>

<div class="section-head">Prochains rendez-vous</div>
{% if upcoming %}
<table class="upcoming-table">
    <thead>
        <tr>
            <th>Date & Heure</th>
            <th>Client</th>
            <th>Service</th>
            <th>Coiffeur</th>
            <th>Statut</th>
        </tr>
    </thead>
    <tbody>
        {% for appt in upcoming %}
        <tr>
            <td><strong>{{ appt.appointmentAt|date('d/m/Y') }}</strong> {{ appt.appointmentAt|date('H:i') }}</td>
            <td>
                {{ appt.clientName }}<br>
                <small style="color:#aaa">{{ appt.clientEmail }}</small>
            </td>
            <td>{{ appt.service.name }}</td>
            <td>{{ appt.barber.name }}</td>
            <td>
                {% if appt.status == 'pending' %}
                    <span class="badge badge-warning">En attente</span>
                {% elseif appt.status == 'confirmed' %}
                    <span class="badge badge-success">Confirmé</span>
                {% else %}
                    <span class="badge badge-danger">Annulé</span>
                {% endif %}
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% else %}
<p style="color:#aaa; font-size:14px">Aucun rendez-vous à venir.</p>
{% endif %}
{% endblock %}
